{
  "version": 1,
  "sources": [
    {
      "id": "grievance_verification",
      "label": "Grievance verification outcome",
      "description": "Check the final verification outcome for a grievance by Applicant ID — includes status, resolution comments, and hearing details.",
      "dataset": "data/grievance_verification.json",
      "recordsPath": "records",
      "match": {
        "field": "applicantId",
        "label": "Applicant ID",
        "inputType": "number",
        "required": true
      },
      "titleField": "title",
      "statusField": "status",
      "emptyStatusValues": ["", "-"],
      "displayFields": [
        { "field": "rowNo", "label": "Row" },
        { "field": "applicantId", "label": "Applicant ID" },
        { "field": "name", "label": "Name" },
        { "field": "title", "label": "Title" },
        { "field": "status", "label": "Status" },
        { "field": "comments", "label": "Comments" },
        { "field": "dated", "label": "Filed at" },
        { "field": "datedStatus", "label": "Last updated" }
      ],
      "response": {
        "intro": "We matched your request to {matchLabel} {matchValue}.",
        "statusLine": "Verification status: {statusValue}.",
        "emptyStatusText": "No verification outcome recorded",
        "extraLine": "Title: {title}\nComments: {comments}\nFiled: {dated}\nStatus: {statusValue}",
        "footer": "Please verify the final outcome on the official PHF/PRP portal, because MeritNama can only explain the data snapshot available to this site. This response was reviewed and approved by admin before delivery."
      }
    }
  ]
}
