// Firestore Security Rules — Deploy these via Firebase Console
// Go to: Firebase Console → Firestore → Rules
//
// These rules ensure:
// 1. Only the auth gate can READ authorized_users (to verify PIN)
// 2. The admin dashboard can READ audit logs through the PIN-gated UI
// 3. Anyone can append audit logs (for logging attempts)
// 4. Nobody can write to authorized_users from client

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authorized users — readable for PIN verification
    // write is allowed so the admin dashboard can add/update users.
    // Security note: since we use client-side PIN auth (no Firebase Auth),
    // writes here are trust-gated by the admin dashboard UI, not Firestore rules.
    match /authorized_users/{email} {
      allow read: if true;
      allow create, update: if true;  // admin dashboard uses hashPin + isAdmin check
      allow delete: if true;           // admin dashboard can remove users
    }

    // Access logs — writable by anyone (for logging), readable only by admin
    match /access_logs/{logId} {
      allow create: if true;
      allow read: if true;   // Admin dashboard reads these; protect via admin PIN check in app
      allow update, delete: if false;
    }

    // Screenshot logs — clients append detected attempts; admin dashboard reads them.
    match /screenshot_logs/{logId} {
      allow create: if true;
      allow read: if true;   // Admin dashboard reads these; protect via admin PIN check in app
      allow update, delete: if false;
    }

    // User warnings/inbox — admin creates; users read and mark their own messages read.
    // Current project uses client-side PIN gating, so access is trust-gated in UI.
    match /user_warnings/{warningId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // Candidate inbox requests — candidates create questions, admin reviews/edits/
    // approves data-responder drafts, candidates read approved replies.
    // Current project uses client-side PIN gating, so access is trust-gated in UI.
    match /inbox_requests/{messageId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // User activity history — clients append location context; admin dashboard reads history.
    match /user_activity_logs/{activityId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }

    // Training reviews — publicly readable and creatable, no edits/deletes
    match /training_reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Hospital-specific reviews — publicly readable and creatable, no edits/deletes
    // Document fields: hospitalId, hospitalName, specialty (nullable), author, year,
    //                  rating, text, createdAt
    // Note: Queries filtered by (hospitalId + specialty) require a composite index.
    //       Create it in Firebase Console → Firestore → Indexes:
    //         Collection: hospital_reviews  Fields: hospitalId ASC, specialty ASC, createdAt DESC
    match /hospital_reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Mentorship requests — created by authenticated users, read by admin
    match /mentorship_requests/{requestId} {
      allow create: if true;   // gated by PIN-based auth in client app
      allow read:   if true;   // admin dashboard reads these
      allow update, delete: if false;
    }

    // Mentors — verified trainees who register to mentor applicants
    // Doc ID = mentor email. Read by all (for matching), written by the mentor themselves.
    // Queries: mentors.where('available','==',true).where('hospital','==',x)
    //          mentors.where('available','==',true).where('specialty','==',x)
    // Composite indexes needed: (available ASC, hospital ASC) and (available ASC, specialty ASC)
    match /mentors/{mentorEmail} {
      allow read:          if true;   // applicants can query for matching mentors
      allow create, update: if true;  // mentor registers themselves; gated by PIN-based auth
      allow delete:        if false;
    }

    // Presence tracking — each user writes their own doc, admin reads all
    // Doc ID = user email. Written by presence.js on every auth-gated page.
    match /presence/{email} {
      allow read:          if true;   // admin dashboard reads the full collection
      allow create, update: if true;  // presence.js writes on any auth-gated page
      allow delete:        if false;
    }

    // Community discussion threads + replies
    // Threads are publicly readable/creatable. Updates are allowed only to support
    // atomic commentCount increments (FieldValue.increment) when a reply is posted.
    match /discussions/{threadId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;   // needed for commentCount increment on reply
      allow delete: if false;

      // Replies (comments subcollection) — public read/create, no edits/deletes
      match /comments/{commentId} {
        allow read:          if true;
        allow create:        if true;
        allow update, delete: if false;
      }
    }

    // Community feed posts + comments + likes (community.html / js/community.js)
    // Mirrors the /discussions pattern exactly: publicly readable/creatable,
    // update allowed only for the two atomic counters (commentCount via
    // FieldValue.increment on reply, likeCount via increment/decrement on
    // like toggle) using the same reaction-only-update technique already
    // established for sim21_chat (see _sim21ChatReactionOnlyUpdate below).
    // Posts/comments themselves are delete:false at the rules layer — the UI
    // only shows a delete button to the post's own author, same trust model
    // as every other collection in this app (no Firebase Auth to enforce it
    // server-side).
    match /social_posts/{postId} {
      allow read:   if true;
      allow create: if true;
      allow update: if _socialPostCountOnlyUpdate();
      allow delete: if true;   // UI-gated to the post's own author

      match /comments/{commentId} {
        allow read:   if true;
        allow create: if true;
        allow delete: if true;   // UI-gated to the comment's own author
        allow update: if false;
      }

      // Like toggle — doc ID = liker's email, so a user can only ever have
      // one like doc per post (double-like is structurally impossible) and
      // unliking is just deleting this doc.
      match /likes/{likerEmail} {
        allow read, create, delete: if true;
        allow update: if false;
      }
    }

    // Contributions — publicly readable, writable by admin dashboard
    // Security note: since we use client-side PIN auth (no Firebase Auth),
    // writes are trust-gated by the admin dashboard UI, same as authorized_users.
    match /contributions/{contributionId} {
      allow read: if true;
      allow create, update, delete: if true;  // admin dashboard manages these
    }

    // User profiles — extended user data (aspiring specialty, hospital, etc.)
    // Readable by anyone (shown on reviews/contributions), writable by authenticated users
    // Security note: write access is gated by PIN-based auth in the client app.
    match /user_profiles/{email} {
      allow read: if true;
      allow create, update: if true;  // user can edit their own profile via auth-gated pages
      allow delete: if false;
    }

    // Applicant chat — real-time group chat for applicants
    // Publicly readable and creatable. No edits/deletes to maintain integrity.
    match /applicant_chat/{messageId} {
      allow read:   if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Access requests — candidates submit; admin reads/updates via admin portal
    // Doc ID = email. Fields: applicantId, nameFull, status, paymentDeclared, paymentAmountPKR, paymentReference, message, …
    match /access_requests/{email} {
      allow create: if true;
      allow read:   if true;
      allow update: if true;
      allow delete: if false;
    }

    // Firebase Trigger Email extension queue.
    // Admin dashboard creates documents like:
    //   { to: [email], template: { name: 'welcome_access', data: {...} } }
    // Security note: this follows the current PIN-gated admin-dashboard model.
    // For a hardened deployment, create these documents from a Cloud Function
    // and set client writes here to false.
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Room directory — hospital- and specialty-scoped chat rooms.
    // Previously rooms were a hardcoded client array (CHAT.ROOMS in
    // js/sim-chat.js); this collection makes the room list real data so
    // per-hospital and per-specialty rooms can be added without a code
    // deploy. Messages for these rooms still live in sim21_chat, keyed by
    // this doc's id as roomId — no new message collection needed.
    // Fields: id, label, type ('hospital' | 'specialty' | 'general'),
    //         hospitalName?, specialtyName?, description, icon, createdAt
    match /chat_rooms/{roomId} {
      allow read: if true;
      allow create, update, delete: if true;   // admin console manages these
    }

    // Community chat messages (Induction 21 simulation page)
    // Publicly readable and creatable; delete allowed (ownership enforced in UI).
    // Fields: text, name, uid, email, roomId, roomLabel, ts, type, imageData,
    //         fileData, fileName, fileSize, mimeType, reactions, replyTo,
    //         mentionsEveryone, mentions
    match /sim21_chat/{msgId} {
      allow read, create, delete: if true;
      allow update: if _sim21ChatReactionOnlyUpdate();
    }

    // Ephemeral typing indicators — doc ID = chat uid
    // Fields: uid, name, updatedAt
    match /sim21_chat_typing/{uid} {
      allow read, create, update, delete: if true;
    }

    // Room-level presence for grouped discussions.
    // Doc ID = {roomId}_{chatUid}; fields: uid, email, name, roomId, roomLabel, online, page, updatedAt
    match /sim21_room_presence/{presenceId} {
      allow read, create, update, delete: if true;
    }

    // Job board — scraped from jobz.pk via the in-browser sync button on the
    // Jobs tab and pushed here. Public read (any visitor sees live cards),
    // write allowed so the Scrape & sync button can merge new/changed docs.
    // Doc IDs: {numericJobId}  Special doc: _meta (count, lastSyncAt, source)
    // Per-doc fields see js/app-jobs.js header comment.
    // Second write path (redesign): hospital-submitted postings, doc ID
    // `hosp-{slug}-{slug}-{ts}`, fields source:'hospital', status:
    // 'pending'|'published'|'rejected', specialty, description, posterName,
    // posterEmail, hospitalDomainHint, emailLooksHospitalOwned, reviewedBy,
    // reviewedAt. Same trust model as the rest of this file — status is
    // UI-gated (only the admin console's queue flips pending → published),
    // not rules-gated, since there's no real auth to check a role against.
    match /jobs/{jobId} {
      allow read:          if true;
      allow create, update: if true;   // sync button; trust-gated by client UI
      allow delete:        if false;
    }

    // Live update notifications — admin writes, everyone reads
    // Doc IDs: latest (banner), simulation_feed, marks_config, access_config (request page payment)
    // fetch_progress fields: active, status, percent, fetched, total, title, message, icon,
    //                        startedAt, pausedAt, updatedAt
    // induction_schedule fields: induction, source, steps[], updatedAt
    // profile_status fields: source, statusTypeId, statusTypeLabel, statusLabels, entries[], updatedAt
    // chat_pin fields: active, text, pinnedBy, updatedAt
    // chat_room_pins fields: rooms: { [roomId]: { active, text, pinnedBy, updatedAt } }
    // simulation_config fields: statusScopes[], defaultStatusScopeId, showStatusScopeSelector
    match /notifications/{docId} {
      allow read: if true;
      allow create, update: if true;   // admin dashboard writes; gated by PIN-based auth in client
      allow delete: if false;
    }

    // Web push tokens — users write their own token, admin reads all
    // Doc ID = FCM token  Fields: token, subscribedAt, userAgent
    match /push_subscriptions/{token} {
      allow create, update: if true;   // user subscribes from client
      allow delete:         if true;   // user unsubscribes from client
      allow read:           if false;  // tokens are private; admin reads via Firebase Console
    }

    // Donor-only PDF download audit trail. Clients append logs; no client reads.
    match /download_logs/{logId} {
      allow create: if true;
      allow read: if true;   // Admin dashboard reads these; protect via admin PIN check in app
      allow update, delete: if false;
    }

    // Candidate mark revisions — admin-entered corrections/overrides to a candidate's
    // marks, layered on top of data/induction21_revisions.json in the simulation portal.
    // Doc ID = applicantId. Fields: { [revId]: { _type, _createdAt, _applicantId, ...changedFields } }
    // Security note: same trust model as notifications/authorized_users — writes are
    // gated by the admin dashboard UI, not Firestore rules.
    match /candidate_revisions/{applicantId} {
      allow read: if true;
      allow create, update: if true;   // admin dashboard writes; gated by PIN-based auth in client
      allow delete: if false;
    }

    // Editorial articles — public read for published, full CRUD for admin
    match /editorial_articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // Editorial comments
    match /editorial_comments/{commentId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // Editorial votes
    match /editorial_votes/{voteId} {
      allow read: if true;
      allow create, delete: if true;
      allow update: if false;
    }

    // Admin roles — RBAC for the new admin console. Deliberately a
    // separate collection from authorized_users/isAdmin (the old site's
    // PIN-auth flag) so the redesign's admin work can never break that
    // live auth path. Doc ID = email. Fields: role, name, grantedAt, grantedBy.
    // Security note: same trust model as authorized_users today — no
    // Firebase Auth is wired yet, so this is UI-gated, not rules-gated.
    // That's a real gap, not an oversight: real enforcement needs real
    // sign-in, which doesn't exist for candidates or admins yet either.
    match /admin_roles/{email} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // Verified members — admin-granted badge shown next to a name in
    // Community (e.g. "PRP Alumnus", "Mentor"). Doc ID = chat uid.
    // Fields: name, label, verifiedAt, verifiedBy.
    match /verified_members/{uid} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // Admin audit log — append-only record of admin actions (distinct
    // from access_logs, which only records login attempts). Every admin
    // mutation in the new console writes one entry here.
    // Fields: actorEmail, actorRole, action, targetCollection, targetId,
    //         summary, ts
    match /admin_audit_log/{entryId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Reports — the report mechanism that didn't exist before. A report
    // references the collection+doc it's about; the moderation queue
    // reads this collection rather than each source collection directly.
    // Fields: sourceCollection, sourceId, reason, reporterUid, reporterName,
    //         contentPreview, status ('pending' | 'resolved'), createdAt,
    //         resolvedAction ('removed' | 'dismissed'), resolvedBy, resolvedAt
    match /reports/{reportId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }

    function _sim21ChatReactionOnlyUpdate() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['reactions'])
        && request.resource.data.text == resource.data.text
        && request.resource.data.name == resource.data.name
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.ts == resource.data.ts;
    }

    // Same technique as _sim21ChatReactionOnlyUpdate above, applied to
    // social_posts' two atomic counters (commentCount on reply, likeCount
    // on like/unlike) — an update is only valid if it touches nothing else.
    function _socialPostCountOnlyUpdate() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['commentCount', 'likeCount']);
    }
  }
}
